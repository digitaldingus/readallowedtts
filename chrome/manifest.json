{
  "manifest_version": 3,
  "name": "ReadAllowed",
  "version": "0.1.0",
  "description": "An extension for Antigravity to enhance reading and interaction.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "nativeMessaging"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/128.png"
    }
  },
  "icons": {
    "128": "icons/128.png"
  }
}
