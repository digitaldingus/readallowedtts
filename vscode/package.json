{
  "name": "read-allowed",
  "displayName": "ReadAllowed TTS",
  "description": "High-performance TTS for Antigravity. Just highlight any text and click the Status Bar button (or press Ctrl+Alt+S) to read it instantly.",
  "version": "2.4.2",




  "icon": "icons/128.png",
  "publisher": "digitaldingus",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "keybindings": [
      {
        "command": "read-allowed.start",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s"
      }
    ],
    "commands": [
      {
        "command": "read-allowed.start",
        "title": "Start Speaking",
        "icon": "$(debug-start)"
      },
      {
        "command": "read-allowed.stop",
        "title": "Stop Speaking",
        "icon": "$(debug-stop)"
      },
      {
        "command": "read-allowed.selectVoice",
        "title": "Select Voice",
        "icon": "$(megaphone)"
      }

    ],
    "menus": {
      "view/title": [
        {
          "command": "read-allowed.start",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "read-allowed.start",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "ReadAllowed",
      "properties": {
        "read-allowed.speed": {
          "type": "integer",
          "default": 0,
          "minimum": -10,
          "maximum": 10,
          "description": "Rate of speech synthesis speed (-10 to 10)."
        },
        "read-allowed.voice": {
          "type": "string",
          "default": "",
          "description": "The exact name of the installed voice (e.g., 'Microsoft David')."
        },
        "read-allowed.assistiveMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable audible alerts and automatic state readouts for assistive navigation."
        }

      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/digitaldingus/readallowedtts"
  },
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0"
  }
}
